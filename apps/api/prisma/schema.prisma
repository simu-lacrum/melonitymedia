// ─────────────────────────────────────────────────────────────
// MelonityMedia — Prisma Schema v3.0
// Source of truth for all database models.
//
// Key changes in v3:
// 1. SocialAccount: cookie-based auth (encrypted cookies in DB)
// 2. SocialAccount: per-account fingerprint stored as JSON
// 3. SocialAccount: warmup tracking fields
// 4. Proxy: type classification (LTE_MOBILE, STATIC_RESIDENTIAL, DATACENTER)
// 5. Proxy: carrier/ASN validation fields
// 6. Proxy: rotation cooldown and last rotated timestamp
// 7. AccountStatus: new states (EXPIRED_COOKIES, SHADOWBAN_SUSPECTED, WARMING_UP)
// 8. TaskType: new SHADOWBAN_CHECK type
// ─────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User ────────────────────────────────────────────────────
// The webmaster (traffic arbitrageur) who owns accounts,
// proxies, and tasks. First registered user gets ADMIN role.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         Role      @default(USER)
  maxThreads   Int       @default(3)    // concurrent browser sessions limit
  isBanned     Boolean   @default(false)
  bannedAt     DateTime?
  isApproved   Boolean   @default(false) // admin must approve new registrations
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations — everything a webmaster owns
  accounts     SocialAccount[]
  proxies      Proxy[]
  tasks        Task[]
  videos       Video[]
  videoPublications VideoPublication[]
  banners      Banner[]
  presets      Preset[]
  vncSessions  VncSession[]
  auditLogs      AuditLog[]
  dailySnapshots DailySnapshot[]
}

enum Role {
  USER
  ADMIN
}

// ── Social Account ──────────────────────────────────────────
// TikTok or YouTube account managed by the webmaster.
// Auth: cookie-only. Cookies encrypted with AES-256-GCM.
// Fingerprint generated once and never changed.
model SocialAccount {
  id          String        @id @default(cuid())
  userId      String
  platform    Platform
  username    String?       // optional — display name, not used for auth
  password    String?       // deprecated — kept for migration, not used in v3

  // Login credentials (encrypted, only for fresh login flow)
  loginEncrypted    Bytes?
  loginIv           Bytes?
  loginAuthTag      Bytes?
  passwordEncrypted Bytes?
  passwordIv        Bytes?
  passwordAuthTag   Bytes?
  // After successful login + cookies extracted, these can be cleared.

  // Cookie-based auth (AES-256-GCM encrypted)
  cookiesEncrypted  Bytes?       // AES-256-GCM ciphertext
  cookiesIv         Bytes?       // 12-byte IV for GCM
  cookiesAuthTag    Bytes?       // 16-byte authentication tag
  cookiesUpdatedAt  DateTime?    // last time cookies were refreshed


  // Per-account fingerprint — generated once, NEVER changes
  fingerprint       Json?        // AccountFingerprint JSON
  fingerprintStale  Boolean      @default(false) // true when Chrome version diverges after upgrade

  status      AccountStatus @default(ALIVE)
  lastError   String?       // human-readable reason for AUTH_NEEDED/error status

  // Proxy pinning — one proxy per account, stable for 14+ days
  pinnedProxyId    String?       // currently pinned proxy
  proxyPinnedAt    DateTime?     // when proxy was pinned (14-day rule)

  // Warmup tracking
  warmupDays        Int         @default(10)  // user-configurable warmup duration (3-21)
  warmupStartedAt   DateTime?   // when warmup began (null = not started)
  warmupCompletedAt DateTime?   // when warmup finished (null = in progress)
  lastWarmupDay     Int?        // last completed warmup day (1-based, BUG-M7 fix)

  // Profile metadata
  cookiesPath   String?       // legacy path to cookies file (deprecated)
  avatarUrl     String?
  bannerUrl     String?
  bio           String?
  defaultDescription String?    // default upload description for this account
  nickname      String?       // TikTok @handle
  secUid        String?       // TikTok secUid for API queries
  views         Int           @default(0)
  followers     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinnedProxy Proxy? @relation(fields: [pinnedProxyId], references: [id], onDelete: SetNull)
  videos Video[]
  videoPublications VideoPublication[]
  dailySnapshots DailySnapshot[]
  vncSessions VncSession[]

  @@index([userId])
  @@index([userId, platform])
}

enum Platform {
  TIKTOK
  YOUTUBE
}

enum AccountStatus {
  ALIVE
  ACTIVE
  PAUSED
  AUTH_NEEDED
  BANNED
  EXPIRED_COOKIES
  SHADOWBAN_SUSPECTED
  WARMING_UP
  VERIFYING
}

// ── Proxy ───────────────────────────────────────────────────
// Mobile, residential, or datacenter proxy.
// LTE mobile proxies with IP rotation are preferred for TikTok.
model Proxy {
  id           String      @id @default(cuid())
  userId       String

  // Connection details (parsed from address string)
  host         String
  port         Int
  username     String?
  password     String?
  protocol     ProxyProtocol @default(HTTP)
  address      String      // legacy format: ip:port:login:pass (kept for display)

  // Proxy classification
  type         ProxyType   @default(LTE_MOBILE)

  // IP rotation (for LTE mobile proxies)
  isRotating       Boolean     @default(false)
  rotationLink     String?     // API URL to trigger IP rotation
  rotationCooldown Int         @default(900) // seconds between rotations (15 min)
  lastRotatedAt    DateTime?   // last IP rotation timestamp
  lastIP           String?     // last known external IP (from rotation response or test)
  lastIPAt         DateTime?   // when lastIP was observed

  // Provider integration (optional)
  provider             ProxyProvider @default(MANUAL)
  providerExternalId   String?       // slotId / modemId / proxyName at provider
  providerApiKey       String?       // encrypted; only set when provider != MANUAL
  providerApiKeyIv     Bytes?
  providerApiKeyTag    Bytes?

  // Rotation strategy
  rotationMode         RotationMode  @default(MANUAL)

  // Carrier/ASN validation
  carrier       String?        // e.g., "T-Mobile", "MTS", "Vodafone"
  country       String         @default("US")
  dma           String?        // Designated Market Area (US only)
  asn           Int?           // Autonomous System Number
  bgpPathValid  Boolean        @default(false) // carrier ASN matches expected
  lastValidatedAt DateTime?    // last BGP validation timestamp

  label        String?     // user-friendly name
  status       ProxyStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts SocialAccount[]

  @@index([userId])
}

enum ProxyType {
  LTE_MOBILE
  STATIC_RESIDENTIAL
  DATACENTER_DEPRECATED
}

enum ProxyProtocol {
  HTTP
  SOCKS5
}

enum ProxyProvider {
  MANUAL              // user-entered host:port creds, no API
  PROXYS_IO           // proxys.io / mobileproxy.space
  MOBILEPROXIES_ORG   // mobileproxies.org
  PROXYGROW           // proxygrow.com
  ILLUSORY            // illusory.io
}

enum RotationMode {
  MANUAL        // rotate only on explicit user trigger
  PER_SESSION   // rotate before every browser session
  SCHEDULED     // rotate on a cron (cooldown-respecting)
}

enum ProxyStatus {
  ACTIVE
  DEAD
}

// ── Video ───────────────────────────────────────────────────
// Uploaded video file lifecycle:
// 1. User uploads via DnD → saved to uploads/ dir
// 2. Worker uniquifies video per-account (FFmpeg)
// 3. Worker uploads uniquified version to TikTok/YouTube
// 4. On success → isUploaded=true, uploadedAt=now()
// 5. Cleanup cron → deletes physical file from disk
// 6. DB record stays for analytics (filepath cleared)
model Video {
  id           String    @id @default(cuid())
  userId       String
  filename     String    // sanitized filename on disk
  originalName String    // original upload filename
  filepath     String    // full path on disk (cleared after cleanup)
  mimeType     String
  size         Int       // bytes
  order        Int       @default(0) // drag-n-drop sort order
  isUploaded   Boolean   @default(false)
  uploadedAt   DateTime?
  status       VideoStatus @default(QUEUED)
  shouldDelete Boolean   @default(true) // auto-delete after upload?
  accountId    String?   // which account this video was uploaded to
  description  String?   // user-provided video description
  hashtags     String[]  // array of hashtag strings (without #)
  views        Int       @default(0) // views count from analytics
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  account SocialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  publications VideoPublication[]

  @@index([userId])
  @@index([userId, isUploaded])
  @@index([status])
}

enum VideoStatus {
  QUEUED
  PROCESSING
  UPLOADED
  FAILED
}

// ── Video Publication ───────────────────────────────────────
// Per-account publication history for a source video.
// A single uploaded source file may be published to many accounts; this
// table is the source of truth for per-account rate limits, shadowban checks,
// idempotency, and cleanup decisions.
model VideoPublication {
  id          String                 @id @default(cuid())
  userId      String
  videoId     String
  accountId   String
  taskId      String?
  status      VideoPublicationStatus @default(QUEUED)
  uploadedAt  DateTime?
  views       Int                    @default(0)
  error       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  video   Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  account SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([videoId, accountId])
  @@index([userId])
  @@index([accountId, uploadedAt])
  @@index([videoId, status])
  @@index([taskId])
}

enum VideoPublicationStatus {
  QUEUED
  PROCESSING
  UPLOADED
  FAILED
  SKIPPED
}

// ── Banner ──────────────────────────────────────────────────
// Animated video banner overlaid onto uploaded videos.
// Stored per-user. Supports alpha-channel or black-bg banners.
model Banner {
  id           String   @id @default(cuid())
  userId       String
  filename     String   // sanitized filename on disk
  originalName String   // original upload filename
  filepath     String   // full path on disk
  mimeType     String
  size         Int      // bytes
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Task ────────────────────────────────────────────────────
// A BullMQ job wrapper. Tracks status, progress, errors.
model Task {
  id          String     @id @default(cuid())
  userId      String
  type        TaskType
  status      TaskStatus @default(PENDING)
  config      Json       // mode-specific settings
  bullmqJobId String?    // BullMQ job ID for tracking
  progress    Int        @default(0)  // 0-100
  error       String?
  accountId    String?    // denormalized for fast cancel lookup (shadowban, etc.)
  cancelReason String?    // e.g. "SHADOWBAN_SUSPECTED"
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vncSessions VncSession[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([accountId])
}

enum TaskType {
  UPLOAD
  WARMUP
  COOKIES
  EDIT_PROFILE
  ANALYTICS_CRON
  SHADOWBAN_CHECK
  LOGIN
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model VncSession {
  id        String           @id @default(cuid())
  userId    String
  taskId    String
  accountId String
  jobId     String
  display   Int
  vncPort   Int
  webPort   Int
  password  String
  status    VncSessionStatus @default(ACTIVE)
  startedAt DateTime         @default(now())
  endedAt   DateTime?
  updatedAt DateTime         @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  task    Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  account SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([taskId, jobId])
  @@index([userId, status])
  @@index([taskId, status])
  @@index([accountId])
}

enum VncSessionStatus {
  ACTIVE
  CLOSED
}

// ── Preset ──────────────────────────────────────────────────
// Saved workspace configuration.
model Preset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  config    Json     // full workspace state snapshot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Audit Log ───────────────────────────────────────────────
// Admin action tracking.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // null for system actions
  action    String   // e.g., "user.ban", "shadowban.detected"
  details   Json?    // action-specific data
  ip        String?  // requester IP
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ── DailySnapshot ───────────────────────────────────────────
// One row per account per day. Upserted by analytics cron.
// Enables real time-series charts on the dashboard.
model DailySnapshot {
  id          String   @id @default(cuid())
  accountId   String
  userId      String
  date        DateTime @db.Date   // calendar date (no time), e.g. 2026-06-16
  views       Int      @default(0)
  followers   Int      @default(0)
  likes       Int      @default(0)
  videos      Int      @default(0)
  createdAt   DateTime @default(now())

  account SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])  // one snapshot per account per day
  @@index([userId, date])
}
